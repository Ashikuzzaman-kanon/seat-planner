# Server
PORT=4000
NODE_ENV=development
# Comma-separated list of allowed origins for CORS
CORS_ORIGINS=http://localhost:3000

# Database (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=seat_planner
DB_USER=root
DB_PASS=

# JWT
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# Email verification expiry (minutes)
VERIFICATION_CODE_TTL_MIN=15

# SMTP (optional in development — if EMAIL_HOST is empty, codes are logged to console)
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM="Seat Planner <no-reply@seatplanner.local>"

# Bootstrap super admin (used by `npm run seed:superadmin`)
SUPER_ADMIN_NAME=Super Admin
SUPER_ADMIN_EMAIL=superadmin@example.com
SUPER_ADMIN_PASSWORD=ChangeMe123!
