# Copy this to ".env" (same folder as docker-compose.yml) and fill in real
# values. Compose reads ".env" automatically for ${VAR} substitution.
# NEVER commit the real .env — only this example.

# --- Database ---
DB_NAME=seat_planner
DB_USER=seatplanner            # non-root app user, created by the db container
DB_PASS=change-me-app-password
MYSQL_ROOT_PASSWORD=change-me-root-password

# --- Auth ---
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# --- Reverse proxy ---
# Local: leave as :80  →  http://localhost
# Server: set to your domain (e.g. seatplanner.example.com) for auto-HTTPS
SITE_ADDRESS=:80
# Must match how the browser reaches the app (origin), for CORS:
CORS_ORIGINS=http://localhost

# --- SMTP (optional; blank host = verification codes log to backend console) ---
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=Seat Planner <no-reply@seatplanner.local>

# --- Bootstrap super admin (used by `npm run seed:superadmin`) ---
SUPER_ADMIN_NAME=Super Admin
SUPER_ADMIN_EMAIL=superadmin@example.com
SUPER_ADMIN_PASSWORD=ChangeMe123!
